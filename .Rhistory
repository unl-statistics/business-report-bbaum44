library(readxl)
library(tidyverse)
# Load raw data
r8    <- read_excel("case-and-demographic-characteristics-table-r8-2023-2024.xlsx",
col_names = FALSE)
r100  <- read_excel("case-and-demographic-characteristics-table-r100-2023-2024.xlsx",
col_names = FALSE)
fatal <- read_excel("fatal.xlsx", col_names = FALSE)
# --- Pull key numbers directly by row/column position ---
# R8: row 1 = header, row 2 = sub-header, data starts row 3
# Column layout (0-indexed in Python, 1-indexed in R):
#   col 1 = industry, col 2 = NAICS, col 3 = case type
#   col 4 = total rate, col 10 = falls total
r8_data <- r8[-c(1,2), ]  # drop header rows
names(r8_data)[1]  <- "industry"
names(r8_data)[2]  <- "naics"
names(r8_data)[3]  <- "case_type"
names(r8_data)[4]  <- "total_rate"
names(r8_data)[10] <- "fall_rate"
# Manufacturing (NAICS 31-33, DAFW only)
mfg <- r8_data |> filter(naics == "31-33", case_type == "DAFW")
mfg_total <- as.numeric(mfg$total_rate[1])   # 86.4
mfg_falls <- as.numeric(mfg$fall_rate[1])    # 18.7
# Finance and insurance (NAICS 52, DAFW only)
fin <- r8_data |> filter(naics == "52", case_type == "DAFW")
fin_total <- as.numeric(fin$total_rate[1])   # 11.0
fin_falls <- as.numeric(fin$fall_rate[1])    # 3.7
# Professional services (NAICS 54, DAFW only)
pro <- r8_data |> filter(naics == "54", case_type == "DAFW")
pro_total <- as.numeric(pro$total_rate[1])   # 18.6
pro_falls <- as.numeric(pro$fall_rate[1])    # 4.3
# --- Fatal injury data ---
# fatal.xlsx: col 3 = total fatalities, col 7 = falls
fatal_data <- fatal[-c(1,2,3,4,5), ]
names(fatal_data)[1] <- "industry"
names(fatal_data)[3] <- "total_fatal"
names(fatal_data)[7] <- "fatal_falls"
# Manufacturing fatal (row 142 in original = row ~137 after removing headers)
mfg_fatal_total <- 353
mfg_fatal_falls <- 52
# Finance and insurance fatal
fin_fatal_total <- 18
fin_fatal_falls <- 6
# Professional services fatal
pro_fatal_total <- 65
pro_fatal_falls <- 10
# Fall percentages
mfg_fall_pct <- round(mfg_fatal_falls / mfg_fatal_total * 100, 1)
fin_fall_pct <- round(fin_fatal_falls / fin_fatal_total * 100, 1)
pro_fall_pct <- round(pro_fatal_falls / pro_fatal_total * 100, 1)
tibble(
Sector = c("Manufacturing", "Finance & Insurance", "Professional Services"),
`Total Injury Rate` = c(mfg_total, fin_total, pro_total),
`Fall-Specific Rate` = c(mfg_falls, fin_falls, pro_falls)
) |>
knitr::kable(
caption = "Nonfatal injury rates per 10,000 FTE workers (SOII, 2023–2024)"
)
tibble(
Sector = c("Manufacturing", "Finance & Insurance", "Professional Services"),
`Total Deaths` = c(mfg_fatal_total, fin_fatal_total, pro_fatal_total),
`Deaths from Falls` = c(mfg_fatal_falls, fin_fatal_falls, pro_fatal_falls),
`Falls as % of Deaths` = c(mfg_fall_pct, fin_fall_pct, pro_fall_pct)
) |>
knitr::kable(
caption = "Fatal occupational injuries (CFOI, 2024)"
)
library(readxl)
library(tidyverse)
# Load raw data
r8    <- read_excel("case-and-demographic-characteristics-table-r8-2023-2024.xlsx",
col_names = FALSE)
r100  <- read_excel("case-and-demographic-characteristics-table-r100-2023-2024.xlsx",
col_names = FALSE)
fatal <- read_excel("fatal.xlsx", col_names = FALSE)
r8_data <- r8[-c(1,2), ]
names(r8_data)[1]  <- "industry"
names(r8_data)[2]  <- "naics"
names(r8_data)[3]  <- "case_type"
names(r8_data)[4]  <- "total_rate"
names(r8_data)[10] <- "fall_rate"
# Manufacturing
mfg <- r8_data |> filter(naics == "31-33", case_type == "DAFW")
mfg_total <- as.numeric(mfg$total_rate[1])   # 86.4
mfg_falls <- as.numeric(mfg$fall_rate[1])    # 18.7
# Finance and insurance
fin <- r8_data |> filter(naics == "52", case_type == "DAFW")
fin_total <- as.numeric(fin$total_rate[1])   # 11.0
fin_falls <- as.numeric(fin$fall_rate[1])    # 3.7
# Professional services
pro <- r8_data |> filter(naics == "54", case_type == "DAFW")
pro_total <- as.numeric(pro$total_rate[1])   # 18.6
pro_falls <- as.numeric(pro$fall_rate[1])    # 4.3
# Fatal injury data
fatal_data <- fatal[-c(1,2,3,4,5), ]
names(fatal_data)[1] <- "industry"
names(fatal_data)[3] <- "total_fatal"
names(fatal_data)[7] <- "fatal_falls"
# Manufacturing fatal
mfg_fatal_total <- 353
mfg_fatal_falls <- 52
# Finance and insurance fatal
fin_fatal_total <- 18
fin_fatal_falls <- 6
# Professional services fatal
pro_fatal_total <- 65
pro_fatal_falls <- 10
# Fall percentages
mfg_fall_pct <- round(mfg_fatal_falls / mfg_fatal_total * 100, 1)
fin_fall_pct <- round(fin_fatal_falls / fin_fatal_total * 100, 1)
pro_fall_pct <- round(pro_fatal_falls / pro_fatal_total * 100, 1)
#| label: tbl-fatal
#| tbl-cap: "Fatal occupational injuries by sector (CFOI, 2024)"
#| echo: false
tibble(
Sector = c("Manufacturing", "Finance & Insurance", "Professional Services"),
`Total Deaths` = c(mfg_fatal_total, fin_fatal_total, pro_fatal_total),
`Deaths from Falls` = c(mfg_fatal_falls, fin_fatal_falls, pro_fatal_falls),
`Falls as % of Deaths` = c(
paste0(mfg_fall_pct, "%"),
paste0(fin_fall_pct, "%"),
paste0(pro_fall_pct, "%")
)
) |>
kable()
library(readxl)
library(tidyverse)
library(knitr)
# Load raw data
r8    <- read_excel("case-and-demographic-characteristics-table-r8-2023-2024.xlsx",
col_names = FALSE)
r100  <- read_excel("case-and-demographic-characteristics-table-r100-2023-2024.xlsx",
col_names = FALSE)
fatal <- read_excel("fatal.xlsx", col_names = FALSE)
# --- Nonfatal rates from R8 ---
r8_data <- r8[-c(1, 2), ]
names(r8_data)[1]  <- "industry"
names(r8_data)[2]  <- "naics"
names(r8_data)[3]  <- "case_type"
names(r8_data)[4]  <- "total_rate"
names(r8_data)[10] <- "fall_rate"
mfg <- r8_data |> filter(naics == "31-33", case_type == "DAFW")
mfg_total <- as.numeric(mfg$total_rate[1])  # 86.4
mfg_falls <- as.numeric(mfg$fall_rate[1])   # 18.7
fin <- r8_data |> filter(naics == "52", case_type == "DAFW")
fin_total <- as.numeric(fin$total_rate[1])   # 11.0
fin_falls <- as.numeric(fin$fall_rate[1])    # 3.7
pro <- r8_data |> filter(naics == "54", case_type == "DAFW")
pro_total <- as.numeric(pro$total_rate[1])   # 18.6
pro_falls <- as.numeric(pro$fall_rate[1])    # 4.3
# Fall share of total injuries (nonfatal)
mfg_fall_share <- round(mfg_falls / mfg_total * 100, 1)
fin_fall_share <- round(fin_falls / fin_total * 100, 1)
pro_fall_share <- round(pro_falls / pro_total * 100, 1)
# --- Fatal injury data (hardcoded from CFOI Table A-1) ---
mfg_fatal_total <- 353
mfg_fatal_falls <- 52
fin_fatal_total <- 18
fin_fatal_falls <- 6
pro_fatal_total <- 65
pro_fatal_falls <- 10
mfg_fall_pct <- round(mfg_fatal_falls / mfg_fatal_total * 100, 1)
fin_fall_pct <- round(fin_fatal_falls / fin_fatal_total * 100, 1)
pro_fall_pct <- round(pro_fatal_falls / pro_fatal_total * 100, 1)
#| label: tbl-summary
#| tbl-cap: "Falls as a share of total injuries — nonfatal and fatal comparison"
#| echo: false
tibble(
Sector = c("Manufacturing", "Finance & Insurance", "Professional Services"),
`Falls: % of Nonfatal Injuries` = c(
paste0(mfg_fall_share, "%"),
paste0(fin_fall_share, "%"),
paste0(pro_fall_share, "%")
),
`Falls: % of Deaths` = c(
paste0(mfg_fall_pct, "%"),
paste0(fin_fall_pct, "%"),
paste0(pro_fall_pct, "%")
)
) |>
kable()
#| label: tbl-fatal
#| tbl-cap: "Fatal occupational injuries by sector (CFOI, 2024)"
#| echo: false
tibble(
Sector = c("Manufacturing", "Finance & Insurance", "Professional Services"),
`Total Deaths` = c(mfg_fatal_total, fin_fatal_total, pro_fatal_total),
`Deaths from Falls` = c(mfg_fatal_falls, fin_fatal_falls, pro_fatal_falls),
`Falls as % of Deaths` = c(
